# Mythras Command Nexus — environment example
# Copy to `.env.local` (gitignored) and fill in only what you need.

# ============================================================
# Assistant provider selection
# ============================================================
# v1 (default): local retrieval, runs entirely in the browser, no API key.
#   NEXT_PUBLIC_ASSISTANT_PROVIDER=local
#
# Future: route requests through /api/assistant (requires server runtime +
# implementation in src/app/api/assistant/route.ts or a Netlify Function).
#   NEXT_PUBLIC_ASSISTANT_PROVIDER=api
NEXT_PUBLIC_ASSISTANT_PROVIDER=local

# ============================================================
# AI provider settings (only used when ASSISTANT_PROVIDER=api)
# These are SERVER-ONLY — never expose API keys to the browser.
# ============================================================
# AI_PROVIDER=openai|anthropic|groq|openrouter
# AI_MODEL=gpt-4o-mini       # or claude-3-5-sonnet, llama-3.1-70b, etc.
# OPENAI_API_KEY=
# ANTHROPIC_API_KEY=
# GROQ_API_KEY=
# OPENROUTER_API_KEY=

# ============================================================
# Shop / Stripe checkout (placeholders — NOT wired yet)
# ============================================================
# The site is a static export, so STRIPE_SECRET_KEY / STRIPE_WEBHOOK_SECRET are
# inert until a serverless function exists (see src/lib/shop/checkout.ts).
# For now, shop CTAs route to Discord / email / Streamlabs / affiliate links, or
# you can use Stripe Payment Links (no backend) by pasting the URLs into the data
# files. The publishable key is the only one safe to expose to the browser.
# NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
# STRIPE_SECRET_KEY=sk_test_...            # SERVER-ONLY — needs a serverless fn
# STRIPE_WEBHOOK_SECRET=whsec_...          # SERVER-ONLY — webhook verification
