# Mythras Command Nexus — environment example
# Copy to `.env.local` (gitignored) and fill in only what you need.

# ============================================================
# Assistant provider selection
# ============================================================
# v1 (default): local retrieval, runs entirely in the browser, no API key.
#   NEXT_PUBLIC_ASSISTANT_PROVIDER=local
#
# Future: route requests through /api/assistant (requires server runtime +
# implementation in src/app/api/assistant/route.ts or a Netlify Function).
#   NEXT_PUBLIC_ASSISTANT_PROVIDER=api
NEXT_PUBLIC_ASSISTANT_PROVIDER=local

# ============================================================
# AI provider settings (only used when ASSISTANT_PROVIDER=api)
# These are SERVER-ONLY — never expose API keys to the browser.
# ============================================================
# AI_PROVIDER=openai|anthropic|groq|openrouter
# AI_MODEL=gpt-4o-mini       # or claude-3-5-sonnet, llama-3.1-70b, etc.
# OPENAI_API_KEY=
# ANTHROPIC_API_KEY=
# GROQ_API_KEY=
# OPENROUTER_API_KEY=
